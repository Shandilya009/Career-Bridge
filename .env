# MongoDB Configuration
MONGO_INITDB_DATABASE=CareerBridgeDb

# JWT Configuration
JWT_SECRET=super_secret_career_bridge_key_must_be_long_1234567890

# Backend Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# MongoDB Connection (Docker internal network)
MONGODB_CONNECTION_STRING=mongodb://mongodb:27017
MONGODB_DATABASE_NAME=CareerBridgeDb

# JWT Settings
JWT_ISSUER=CareerBridge
JWT_AUDIENCE=CareerBridgeUsers
JWT_EXPIRY_MINUTES=60

# Frontend Configuration
VITE_API_URL=http://localhost:5001

# Application URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5001

# Email Configuration (Optional - for production)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
